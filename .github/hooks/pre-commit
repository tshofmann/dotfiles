#!/usr/bin/env zsh
# ============================================================
# pre-commit - Git Pre-Commit Hook für dotfiles
# ============================================================
# Zweck       : Verhindert Commits mit veralteter Dokumentation,
#               ungültiger Shell-Syntax oder falscher Formatierung
# Pfad        : .github/hooks/pre-commit
# Install     : git config core.hooksPath .github/hooks
# WICHTIG     : --no-verify ist VERBOTEN (siehe copilot-instructions.md)
# ============================================================

set -uo pipefail

SCRIPT_DIR="${0:A:h}"
DOTFILES_DIR="${SCRIPT_DIR:h:h}"  # .github/hooks → dotfiles
SHELL_COLORS="$DOTFILES_DIR/terminal/.config/theme-style"

# Farben (Catppuccin Mocha) – zentral definiert
[[ -f "$SHELL_COLORS" ]] && source "$SHELL_COLORS"

# Logging (konsistent mit anderen Skripten)
log()  { echo -e "${C_BLUE:-}→${C_RESET:-} $1"; }
ok()   { echo -e "${C_GREEN:-}✔${C_RESET:-} $1"; }
warn() { echo -e "${C_YELLOW:-}⚠${C_RESET:-} $1"; }
err()  { echo -e "${C_RED:-}✖${C_RESET:-} $1" >&2; }

# ------------------------------------------------------------
# 1. Shell-Syntax prüfen
# ------------------------------------------------------------
check_shell_syntax() {
    log "Prüfe Shell-Syntax..."
    local errors=0

    # POSIX-Dateien zuerst mit sh -n prüfen (install.sh + logging.sh)
    for file in "$DOTFILES_DIR"/setup/install.sh \
                "$DOTFILES_DIR"/setup/lib/logging.sh; do
        if [[ -f "$file" ]]; then
            if ! sh -n "$file" 2>/dev/null; then
                err "POSIX-Syntax-Fehler in: ${file#$DOTFILES_DIR/}"
                sh -n "$file" 2>&1 | head -3
                (( errors++ )) || true
            fi
        fi
    done

    # ZSH-Dateien prüfen: .sh, .alias, .zsh, .zshrc, .zshenv, .zprofile, .zlogin
    # POSIX-Dateien (install.sh, logging.sh) werden übersprungen
    # fzf-Helper ohne Extension: config und *.zsh ausschließen (werden gesourced)
    for file in "$DOTFILES_DIR"/.github/scripts/**/*.sh(N) \
                "$DOTFILES_DIR"/terminal/.config/alias/*.alias(N) \
                "$DOTFILES_DIR"/terminal/.config/fzf/*(N) \
                "$DOTFILES_DIR"/terminal/.config/**/*.zsh(N) \
                "$DOTFILES_DIR"/terminal/.zsh*(N) \
                "$DOTFILES_DIR"/terminal/.zprofile(N) \
                "$DOTFILES_DIR"/terminal/.zlogin(N) \
                "$DOTFILES_DIR"/setup/bootstrap.sh(N) \
                "$DOTFILES_DIR"/setup/restore.sh(N) \
                "$DOTFILES_DIR"/setup/modules/*.sh(N); do
        if [[ -f "$file" ]]; then
            # fzf config ist kein Shell-Skript
            [[ "${file:t}" == "config" ]] && continue
            if ! zsh -n "$file" 2>/dev/null; then
                err "Syntax-Fehler in: ${file#$DOTFILES_DIR/}"
                zsh -n "$file" 2>&1 | head -3
                (( errors++ )) || true
            fi
        fi
    done

    if (( errors > 0 )); then
        err "$errors Datei(en) mit Syntax-Fehlern"
        return 1
    fi

    ok "Shell-Syntax OK"
    return 0
}

# ------------------------------------------------------------
# 2. Dokumentation prüfen
# ------------------------------------------------------------
check_docs() {
    log "Prüfe ob Dokumentation aktuell ist..."

    if ! "$DOTFILES_DIR/.github/scripts/generate-docs.sh" --check >/dev/null 2>&1; then
        err "Dokumentation ist veraltet!"
        print ""
        print "  ${C_DIM}Bitte ausführen:${C_RESET}"
        print "    ${C_BOLD}./.github/scripts/generate-docs.sh --generate${C_RESET}"
        print ""
        print "  ${C_DIM}Dann erneut committen.${C_RESET}"
        return 1
    fi

    ok "Dokumentation ist aktuell"
    return 0
}

# ------------------------------------------------------------
# 3. Execute-Berechtigungen prüfen (delegiert an gemeinsames Skript)
# ------------------------------------------------------------
check_executable_permissions() {
    "$DOTFILES_DIR/.github/scripts/check-executable-permissions.sh"
}

# ------------------------------------------------------------
# 4. Alias-Datei-Format prüfen (delegiert an gemeinsames Skript)
# ------------------------------------------------------------
check_alias_format() {
    "$DOTFILES_DIR/.github/scripts/check-alias-format.sh"
}

# ------------------------------------------------------------
# 5. Header-Einrückungen prüfen (delegiert an gemeinsames Skript)
# ------------------------------------------------------------
check_header_alignment() {
    "$DOTFILES_DIR/.github/scripts/check-header-alignment.sh"
}

# ------------------------------------------------------------
# 6. Plattform-Sync prüfen (delegiert an gemeinsames Skript)
# ------------------------------------------------------------
check_platform_sync() {
    "$DOTFILES_DIR/.github/scripts/check-platform-sync.sh"
}

# ------------------------------------------------------------
# 7. Brewfile-Mapping prüfen (delegiert an gemeinsames Skript)
# ------------------------------------------------------------
check_brewfile_mapping() {
    "$DOTFILES_DIR/.github/scripts/check-brewfile-mapping.sh"
}

# ------------------------------------------------------------
# 8. Markdown-Lint prüfen
# ------------------------------------------------------------
check_markdown() {
    log "Prüfe Markdown-Dateien..."

    # markdownlint-cli2 verfügbar?
    if ! command -v markdownlint-cli2 >/dev/null 2>&1; then
        warn "markdownlint-cli2 nicht gefunden – übersprungen"
        warn "Installieren mit: brew install markdownlint-cli2"
        return 0  # Kein Fehler, nur Warnung
    fi

    # Markdownlint ausführen (Ausgabe nur bei Fehlern)
    local output
    output=$(markdownlint-cli2 --config "$DOTFILES_DIR/terminal/.config/markdownlint-cli2/.markdownlint-cli2.jsonc" '**/*.md' '#node_modules' 2>&1)
    local exit_code=$?

    if (( exit_code != 0 )); then
        err "Markdown-Fehler gefunden!"
        # Nur relevante Zeilen anzeigen (keine "Finding:", "Linting:", "Summary:")
        echo "$output" | grep -v "^Finding:" | grep -v "^Linting:" | grep -v "^Summary:" | grep -v "^markdownlint-cli2"
        print ""
        print "  ${C_DIM}Fehler beheben oder Generatoren anpassen:${C_RESET}"
        print "    ${C_BOLD}.github/scripts/generators/*.sh${C_RESET}"
        return 1
    fi

    ok "Markdown OK"
    return 0
}

# ------------------------------------------------------------
# 9. Health-Check ausführen (NUR lokal, nicht in CI)
# Prüft reale Installation: Symlinks, Homebrew-Pakete, Fonts,
# Plattform-Abstraktionen, Theme-Dateien – setzt vollständiges
# Setup voraus, das in CI nicht vorhanden ist.
# Siehe auch: .github/workflows/validate.yml (Checks 1–8)
# ------------------------------------------------------------
check_health() {
    log "Führe Health-Check aus..."

    local health_script="$DOTFILES_DIR/.github/scripts/health-check.sh"

    if [[ ! -f "$health_script" ]]; then
        err "health-check.sh nicht gefunden: $health_script"
        return 1
    fi

    if [[ ! -x "$health_script" ]]; then
        err "health-check.sh nicht ausführbar – chmod +x erforderlich"
        return 1
    fi

    # Health-Check ausführen (Ausgabe unterdrücken, nur Exit-Code prüfen)
    if ! "$health_script" >/dev/null 2>&1; then
        err "Health-Check fehlgeschlagen!"
        print ""
        print "  ${C_DIM}Details anzeigen mit:${C_RESET}"
        print "    ${C_BOLD}./.github/scripts/health-check.sh${C_RESET}"
        return 1
    fi

    ok "Health-Check OK"
    return 0
}

# ------------------------------------------------------------
# 10. fzf header-wrap Selbsttests
# Prüft den dynamischen Header-Umbruch-Algorithmus mit
# verschiedenen Breiten, Gruppen und Edge-Cases.
# Läuft auch in CI (siehe .github/workflows/validate.yml)
# ------------------------------------------------------------
check_header_wrap() {
    log "Führe header-wrap Selbsttests aus..."

    local helper="$DOTFILES_DIR/terminal/.config/fzf/header-wrap"

    if [[ ! -f "$helper" ]]; then
        err "header-wrap nicht gefunden: $helper"
        return 1
    fi

    if [[ ! -x "$helper" ]]; then
        err "header-wrap nicht ausführbar – chmod +x erforderlich"
        return 1
    fi

    # Selbsttests ausführen (Ausgabe unterdrücken, nur Exit-Code prüfen)
    if ! "$helper" --test >/dev/null 2>&1; then
        err "header-wrap Selbsttests fehlgeschlagen!"
        print ""
        print "  ${C_DIM}Details anzeigen mit:${C_RESET}"
        print "    ${C_BOLD}~/.config/fzf/header-wrap --test${C_RESET}"
        return 1
    fi

    ok "header-wrap Selbsttests OK"
    return 0
}

# ------------------------------------------------------------
# 11. Generator Unit Tests
# Prüft die Parser-Funktionen der Dokumentations-Generatoren
# mit isolierten Unit Tests (pure functions).
# Läuft auch in CI (siehe .github/workflows/validate.yml)
# ------------------------------------------------------------
check_generator_tests() {
    "$DOTFILES_DIR/.github/scripts/tests/run-all.sh"
}

# ------------------------------------------------------------
# 12. Keybinding-Sync (Drift-Prävention)
# Prüft ob die Keybinding-Texte in allen Quellen synchron sind:
# a) Beschreibungskommentar ↔ header-wrap (SSOT = Kommentar)
# b) init.zsh Header-Kommentar ↔ Bindkey-Beschreibungen (SSOT = Bindkey)
# Läuft auch in CI (siehe .github/workflows/validate.yml)
# ------------------------------------------------------------
check_header_sync() {
    "$DOTFILES_DIR/.github/scripts/check-header-sync.sh"
}

# ------------------------------------------------------------
# 13. Screenshot-Drift Warnung (nicht-blockierend)
# Prüft ob staged Änderungen Screenshots in docs/assets/ betreffen.
# Warnt bei: neuen/entfernten .alias-Dateien (→ cmds-Liste),
# Dateistruktur-Änderungen in setup/ (→ Tree-View),
# Theme/Layout-Änderungen (→ visuelle Darstellung).
# ------------------------------------------------------------
check_screenshot_drift() {
    # Nur prüfen wenn Screenshots existieren
    local assets_dir="$DOTFILES_DIR/docs/assets"
    [[ -f "$assets_dir/hero.png" || -f "$assets_dir/workflow.png" || -f "$assets_dir/theme.png" ]] || return 0

    local staged_files
    staged_files=$(git diff --cached --name-only --diff-filter=ACDMR 2>/dev/null)
    [[ -z "$staged_files" ]] && return 0

    local -a reasons=()

    # hero.png: Neue/entfernte .alias-Dateien → cmds-Liste ändert sich
    if echo "$staged_files" | grep -qE '\.alias$' && \
       git diff --cached --diff-filter=AD --name-only 2>/dev/null | grep -qE '\.alias$'; then
        reasons+=("Alias-Datei hinzugefügt/entfernt → hero.png (cmds)")
    fi

    # hero.png: Aliase-Header geändert → sichtbare Befehle ändern sich
    if echo "$staged_files" | grep -qE '\.alias$'; then
        if git diff --cached -- '*.alias' 2>/dev/null | grep -qE '^\+.*# Aliase|^-.*# Aliase'; then
            reasons+=("Aliase-Header geändert → hero.png (cmds)")
        fi
    fi

    # theme.png: Dateien in setup/ hinzugefügt/entfernt → Tree ändert sich
    if git diff --cached --diff-filter=AD --name-only 2>/dev/null | grep -qE '^setup/'; then
        reasons+=("Datei in setup/ hinzugefügt/entfernt → theme.png")
    fi

    # Alle: Theme-/Layout-Dateien geändert → visuelle Darstellung
    local -a visual_files=(
        "terminal/.config/theme-style"
        "terminal/.config/fzf/config"
        "terminal/.config/starship/starship.toml"
        "terminal/.config/eza/theme.yml"
    )
    for vf in "${visual_files[@]}"; do
        if echo "$staged_files" | grep -qF "$vf"; then
            reasons+=("${vf##*/} geändert → Screenshots prüfen")
        fi
    done

    if (( ${#reasons[@]} > 0 )); then
        warn "Screenshots in docs/assets/ könnten veraltet sein:"
        for reason in "${reasons[@]}"; do
            print "  ${C_DIM}• $reason${C_RESET}"
        done
        print "  ${C_DIM}→ Screenshots neu erstellen falls sichtbare Änderungen${C_RESET}"
    fi

    # Nie blockierend – immer return 0
    return 0
}

# ------------------------------------------------------------
# 14. Bild-Metadaten strippen (blockierend)
# Entfernt EXIF/XMP-Metadaten aus staged PNG-Dateien in docs/assets/.
# Verhindert dass persönliche Daten (GPS, Benutzername, Software)
# ins Repository gelangen. Nutzt exiftool (Perl, Cross-Platform).
# ------------------------------------------------------------
check_image_metadata() {
    local assets_dir="$DOTFILES_DIR/docs/assets"

    # Staged PNG-Dateien in docs/assets/ finden
    local -a staged_pngs=()
    local file
    while IFS= read -r file; do
        [[ -n "$file" ]] && staged_pngs+=("$file")
    done < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '^docs/assets/.*\.png$')

    # Nichts zu tun wenn keine PNGs staged sind
    [[ ${#staged_pngs[@]} -eq 0 ]] && return 0

    log "Prüfe Bild-Metadaten in docs/assets/..."

    # exiftool verfügbar?
    if ! command -v exiftool >/dev/null 2>&1; then
        err "exiftool nicht gefunden – wird für Metadaten-Strip benötigt"
        print ""
        print "  ${C_DIM}Installieren mit:${C_RESET}"
        print "    ${C_BOLD}brew install exiftool${C_RESET}"
        return 1
    fi

    local stripped=0
    for file in "${staged_pngs[@]}"; do
        local full_path="$DOTFILES_DIR/$file"
        [[ -f "$full_path" ]] || continue

        # Checksum vor Strip merken
        local hash_before
        hash_before=$(shasum -a 256 "$full_path" | awk '{print $1}')

        # Metadaten entfernen (idempotent – keine Änderung wenn bereits sauber)
        if ! exiftool -all= -overwrite_original "$full_path" >/dev/null 2>&1; then
            err "Metadaten-Strip fehlgeschlagen: $file"
            return 1
        fi

        # Prüfe ob sich Datei geändert hat
        local hash_after
        hash_after=$(shasum -a 256 "$full_path" | awk '{print $1}')

        if [[ "$hash_before" != "$hash_after" ]]; then
            git add "$full_path"
            (( stripped++ )) || true
        fi
    done

    if (( stripped > 0 )); then
        ok "Metadaten aus $stripped Bild(ern) entfernt und staged"
    else
        ok "Bild-Metadaten OK (keine zu entfernen)"
    fi

    return 0
}

# ------------------------------------------------------------
# Hauptprogramm
# ------------------------------------------------------------
print ""
print "${C_OVERLAY0}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
print "${C_MAUVE}🔍 ${C_BOLD}Pre-Commit Checks${C_RESET}"
print "${C_OVERLAY0}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
print ""

failed=0

check_shell_syntax || { (( failed++ )) || true; }
check_executable_permissions || { (( failed++ )) || true; }
check_docs || { (( failed++ )) || true; }
check_alias_format || { (( failed++ )) || true; }
check_header_alignment || { (( failed++ )) || true; }
check_platform_sync || { (( failed++ )) || true; }
check_brewfile_mapping || { (( failed++ )) || true; }
check_markdown || { (( failed++ )) || true; }
check_health || { (( failed++ )) || true; }
check_header_wrap || { (( failed++ )) || true; }
check_generator_tests || { (( failed++ )) || true; }
check_header_sync || { (( failed++ )) || true; }
check_image_metadata || { (( failed++ )) || true; }

# Nicht-blockierende Warnungen (nach allen harten Checks)
check_screenshot_drift

print ""
print "${C_OVERLAY0}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"

if (( failed > 0 )); then
    print ""
    err "Pre-Commit fehlgeschlagen (${C_BOLD}$failed${C_RESET}${C_RED} Check(s))"
    print ""
    print "  ${C_RED}${C_BOLD}--no-verify ist VERBOTEN!${C_RESET}"
    print "  ${C_DIM}Bitte Fehler beheben und erneut committen.${C_RESET}"
    exit 1
fi

print ""
ok "Alle Checks bestanden"
exit 0
